<%- include('partials/header') %>

    <main class="container login-main">
        <div class="login-box">

            <% if (typeof error !=='undefined' && error && error.length> 0) { %>
                <div class="flash flash-error">
                    <span class="flash-icon">!</span>
                    <% error.forEach(function(msg) { %><span>
                            <%= msg %>
                        </span>
                        <% }); %>
                </div>
                <% } %>

                    <h1 class="login-title">🤫 WhisperWall</h1>
                    <p class="login-tagline">Say it. Stay anonymous. Always.</p>

                    <a href="/auth/google" class="btn btn-google-big">
                        <svg width="18" height="18" viewBox="0 0 48 48">
                            <path fill="#EA4335"
                                d="M24 9.5c3.54 0 6.72 1.22 9.22 3.22l6.87-6.87C35.91 2.38 30.28 0 24 0 14.62 0 6.52 5.38 2.56 13.22l8.04 6.24C12.52 13.18 17.87 9.5 24 9.5z" />
                            <path fill="#4285F4"
                                d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                            <path fill="#FBBC05"
                                d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-8.04-6.24C.96 16.46 0 20.12 0 24c0 3.88.96 7.54 2.49 10.83l8.04-6.24z" />
                            <path fill="#34A853"
                                d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.13 0-11.48-3.68-13.4-9l-8.04 6.24C6.52 42.62 14.62 48 24 48z" />
                        </svg>
                        Continue with Google
                    </a>

                    <div class="login-divider"><span>what you get</span></div>

                    <div class="login-features">
                        <div class="feature-row">
                            <span class="feature-icon">🔒</span>
                            <div>
                                <strong>Total Anonymity</strong>
                                <span>No name. No trace.</span>
                            </div>
                        </div>
                        <div class="feature-row">
                            <span class="feature-icon">🗝️</span>
                            <div>
                                <strong>Secret Code Protection</strong>
                                <span>Only you can edit or delete.</span>
                            </div>
                        </div>
                        <div class="feature-row">
                            <span class="feature-icon">❤️</span>
                            <div>
                                <strong>Community Reactions</strong>
                                <span>Like, Love &amp; Laugh.</span>
                            </div>
                        </div>
                    </div>

        </div>
    </main>

    <%- include('partials/footer') %>