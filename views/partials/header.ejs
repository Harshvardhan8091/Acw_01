<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Whisper Wall — Anonymous Confessions</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,300;0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;0,14..32,800;1,14..32,400&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
</head>

<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-title">
        <span class="logo-icon">🤫</span>
        <span class="logo-text">Whisper<span class="logo-accent">Wall</span></span>
      </a>
      <nav class="nav-links">
        <% if (typeof user !=='undefined' && user) { %>
          <div class="user-pill">
            <span class="user-dot"></span>
            <span>
              <%= user.displayName.split(' ')[0] %></span>
          </div>
          <% if (typeof isAdmin !== ' undefined' && isAdmin) { %>
                <a href="/admin" class="btn btn-admin-nav">🛡️ Admin</a>
                <% } %>
                  <a href="/logout" class="btn btn-logout">Sign out</a>
                  <% } else { %>
                    <a href="/auth/google" class="btn btn-google-nav">
                      <svg width="15" height="15" viewBox="0 0 48 48">
                        <path fill="#EA4335"
                          d="M24 9.5c3.54 0 6.72 1.22 9.22 3.22l6.87-6.87C35.91 2.38 30.28 0 24 0 14.62 0 6.52 5.38 2.56 13.22l8.04 6.24C12.52 13.18 17.87 9.5 24 9.5z" />
                        <path fill="#4285F4"
                          d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                        <path fill="#FBBC05"
                          d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-8.04-6.24C.96 16.46 0 20.12 0 24c0 3.88.96 7.54 2.49 10.83l8.04-6.24z" />
                        <path fill="#34A853"
                          d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.13 0-11.48-3.68-13.4-9l-8.04 6.24C6.52 42.62 14.62 48 24 48z" />
                      </svg>
                      Sign in
                    </a>
                    <% } %>
      </nav>
    </div>
  </header>